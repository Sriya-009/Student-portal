{
  "name": "student-portal-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "client": "npm run start:ui --prefix frontend",
    "server": "npm run dev --prefix backend",
    "start": "npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "build": "npm install --prefix frontend && npm run build --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "jsonwebtoken": "^9.0.3"
  }
}
